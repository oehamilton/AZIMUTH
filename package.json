{
  "name": "azimuth",
  "version": "0.1.0",
  "description": "Antenna pointing: bearing and distance from home to target (short and long path). Windows 11, Electron, offline-first maps.",
  "private": true,
  "type": "module",
  "main": "src/main/electron-main.js",
  "scripts": {
    "test": "node --test test/geo.test.js",
    "test:results": "node scripts/write-test-results.js",
    "build:renderer": "node scripts/build-renderer.js",
    "build:icon": "node scripts/build-icon.js",
    "start": "pnpm run build:renderer && electron .",
    "e2e": "node test/e2e/run-e2e.js",
    "build": "pnpm run build:icon && pnpm run build:renderer && electron-builder",
    "pack": "pnpm run build:icon && pnpm run build:renderer && electron-builder --dir",
    "msix": "pnpm run build:icon && pnpm run build:renderer && electron-builder --win appx"
  },
  "build": {
    "appId": "com.azimuth.app",
    "productName": "AZIMUTH",
    "directories": { "output": "release" },
    "files": ["dist", "src/main", "package.json"],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "appx": {
      "identityName": "AZIMUTH",
      "displayName": "AZIMUTH",
      "publisherDisplayName": "AZIMUTH",
      "backgroundColor": "#252220",
      "languages": ["en-US"]
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "azimuth",
    "bearing",
    "great-circle",
    "antenna",
    "RF"
  ],
  "author": "Project8X, Inc.",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "leaflet": "^1.9.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "world-atlas": "^2.0.2"
  },
  "dependencies": {
    "d3-geo": "^3.1.0",
    "topojson-client": "^3.1.0"
  }
}
